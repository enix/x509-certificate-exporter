# -*- mode: Python -*-
# E2e Tiltfile, run by `task test:e2e` via `tilt -f test/e2e/Tiltfile ci`.
# The cluster + registry lifecycle is owned by the `test:e2e` task in
# Taskfile.yml — its `defer:` cleanup guarantees teardown even if
# anything below fails or the user aborts. Everything in here assumes
# a fresh, dedicated cluster.
#
# Pipeline (resources run in dep order; `tilt ci` exits 0 iff every
# resource reaches Ready):
#   1.  goreleaser release --snapshot (tilt mode) → exports busybox
#                                                   image to local Docker
#   1b. docker build (seed-hostpath image)        → built once per source change
#   2.  tilt push                                 → tags + pushes both images
#                                                   to 127.0.0.1:5001
#   3.  helm install                              → chart deployed with
#                                                   dev + e2e overrides
#   4a. seed (local_resource)                     → applies K8s-resource
#                                                   scenarios (Secrets/CM)
#   4b. seed-hostpath (Job)                       → writes PEMs + symlinks
#                                                   under the node's
#                                                   /var/lib/x509ce-e2e
#   5.  e2e-test                                  → go test -tags=e2e against /metrics
#
# Tilt resolves relative paths against the Tiltfile's directory, so
# every path that points at the repo root goes through the ROOT
# constant below. Local-dir paths (./values.yaml) stay unprefixed.
ROOT = "../.."

# Constants below must match the e2e vars in Taskfile.yml's `e2e` task
# (CLUSTER, REGISTRY, REGISTRY_PORT). If they drift, the cluster created
# by the task and the cluster Tilt deploys to will not be the same.
CLUSTER_NAME = "x509ce-e2e"
REGISTRY_HOST_PORT = 5001
REGISTRY_NAME = "x509ce-e2e-registry"

allow_k8s_contexts("k3d-" + CLUSTER_NAME)
default_registry(
    "127.0.0.1:%d" % REGISTRY_HOST_PORT,
    host_from_cluster="k3d-%s:%d" % (REGISTRY_NAME, REGISTRY_HOST_PORT),
)

IMAGE = "x509-certificate-exporter"
SEED_HOSTPATH_IMAGE = "x509ce-seed-hostpath"

# 1. Build via GoReleaser in "tilt mode" — same Dockerfile.busybox as
# the release pipeline (one image-build codepath for dev + e2e + release).
# See the dev Tiltfile for the full rationale. The custom_build command
# `cd`s to the repo root so the goreleaser config + the binaries land
# where its dockers_v2 entry expects them.
custom_build(
    ref=IMAGE,
    command=" && ".join([
        'cd "%s"' % ROOT,
        'export TILT_IMAGE_REPO="${EXPECTED_REF%:*}"',
        'export TILT_IMAGE_TAG="${EXPECTED_REF##*:}"',
        'export GORELEASER_TILT=1',
        'export IMAGE_NAME=x509-certificate-exporter',
        'goreleaser release --snapshot --skip=publish,sign,sbom,archive,before --clean',
        'docker tag "${EXPECTED_REF}-$(go env GOARCH)" "$EXPECTED_REF"',
    ]),
    deps=[
        ROOT + "/cmd",
        ROOT + "/pkg",
        ROOT + "/internal",
        ROOT + "/go.mod",
        ROOT + "/go.sum",
        ROOT + "/build/Dockerfile.busybox",
        ROOT + "/.goreleaser.yaml",
    ],
    skips_local_docker=False,
)

# 1b. Build the seed-hostpath image. Tiny scratch image carrying just the
# `dev/seed-hostpath` binary, used by the seed Job to materialise hostPath
# fixtures onto the cluster node's filesystem. Keeps the e2e flow
# self-contained — no separate registry, no separate build pipeline,
# rebuilt on any source change to dev/scenarios or dev/seed-hostpath.
docker_build(
    ref=SEED_HOSTPATH_IMAGE,
    context=ROOT,
    dockerfile=ROOT + "/build/Dockerfile.seed-hostpath",
    only=[
        "go.mod",
        "go.sum",
        "dev/scenarios",
        "dev/seed-hostpath",
        "internal",
        "pkg",
    ],
)

# 3. Helm install. No kube-prometheus-stack here: the e2e values disable
# the chart's ServiceMonitor + PrometheusRule (no CRDs to satisfy), and
# the test scrapes /metrics directly via Tilt's port-forward below.
load("ext://helm_resource", "helm_resource")

helm_resource(
    name="x509-certificate-exporter",
    chart=ROOT + "/chart",
    namespace="x509ce-e2e",
    flags=[
        "--create-namespace",
        "--values",
        ROOT + "/dev/values.yaml",
        "--values",
        "./values.yaml",
    ],
    image_deps=[IMAGE],
    image_keys=[("image.registry", "image.repository", "image.tag")],
    # No port_forwards here: the chart's Service selects every exporter
    # pod (Deployment AND DaemonSet) — kubectl port-forward to it would
    # land on a random one. The two side-band local_resources below run
    # `kubectl port-forward` to each workload deterministically.
)

# 4a. Seed K8s-resource scenarios (Secrets, ConfigMaps). Same package the
# dev loop and tests both consume — single source of truth for fixtures.
# Run from the repo root so `go run ./dev/seed` resolves naturally.
local_resource(
    "seed",
    cmd="cd %s && go run ./dev/seed" % ROOT,
    deps=[ROOT + "/dev/seed", ROOT + "/dev/scenarios"],
    resource_deps=["x509-certificate-exporter"],
)

# 4b. Seed hostPath scenarios (PEM files + symlinks on the node). Runs
# as an in-cluster Job because writing to a hostPath needs an in-cluster
# privileged actor. The Job must complete BEFORE the e2e-test runs, but
# can race with the exporter coming up — the exporter polls
# refreshInterval anyway and will pick the files up on its next walk.
k8s_yaml("./seed-hostpath.yaml")
# Tilt auto-detects the `image: x509ce-seed-hostpath` reference in the Job
# spec and wires it to the matching docker_build above — no explicit
# image_deps needed (k8s_resource doesn't accept that arg anyway).
k8s_resource(
    "seed-hostpath",
    resource_deps=["x509-certificate-exporter"],
)

# 4c+4d. Two kubectl port-forwards, one per workload, run as background
# serve_cmd so each lands on a deterministic pod:
#   - 19793 → secretsExporter Deployment (component=secrets), via the
#     in-cluster Service x509-certificate-exporter (chart-default).
#     We address it via deployment/<name> rather than svc/<name> because
#     the chart's Service also selects the DaemonSet pods, and kubectl
#     port-forward svc/... would pick any matching pod.
#   - 19794 → hostPathsExporter DaemonSet (component=host-nodes), via
#     the dedicated extraDeploy Service deployed by test/e2e/values.yaml.
local_resource(
    "secrets-port-forward",
    serve_cmd=" ".join([
        "kubectl",
        "--namespace=x509ce-e2e",
        "port-forward",
        "deployment/x509-certificate-exporter",
        "19793:9793",
    ]),
    resource_deps=["x509-certificate-exporter"],
    readiness_probe=probe(
        period_secs=2,
        http_get=http_get_action(port=19793, path="/metrics"),
    ),
)
local_resource(
    "nodes-port-forward",
    serve_cmd=" ".join([
        "kubectl",
        "--namespace=x509ce-e2e",
        "port-forward",
        "service/x509-certificate-exporter-nodes",
        "19794:9793",
    ]),
    resource_deps=["x509-certificate-exporter"],
    readiness_probe=probe(
        period_secs=2,
        http_get=http_get_action(port=19794, path="/metrics"),
    ),
)

# 5. Run the assertion suite. tilt ci exits non-zero if this fails,
# which propagates back to `task test:e2e` and then to the wrapper's trap.
# Run from the repo root for consistency with the seed step.
local_resource(
    "e2e-test",
    # -timeout=5m bounds a hung suite: without it, an exporter that never
    # becomes Ready or a metric that never converges would pin `tilt ci`
    # until the outer CI runner kills the job (or forever, locally).
    # E2E_METRICS_URL accepts a comma-separated list — we scrape both the
    # secretsExporter Deployment (default Service, 19793) and the
    # hostPathsExporter DaemonSet (custom Service, 19794) and merge.
    cmd=("cd %s && " % ROOT +
         "E2E_METRICS_URL=http://127.0.0.1:19793/metrics,http://127.0.0.1:19794/metrics " +
         "go test -tags=e2e -count=1 -timeout=5m -v ./test/e2e/..."),
    resource_deps=["seed", "seed-hostpath", "secrets-port-forward", "nodes-port-forward"],
)
